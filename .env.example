# Active checkout provider. Supported source value: stripe.
CHECKOUT_PROVIDER=

# Stripe key-mode gate. Live keys require STRIPE_MODE=live or STRIPE_ALLOW_LIVE=true.
STRIPE_MODE=
STRIPE_ALLOW_LIVE=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=

# Server-calculated checkout fee percentage.
PROCESSING_FEE_PERCENT=

# Supabase browser/server configuration.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend and Luna/OpenAI server credentials.
RESEND_API_KEY=
OPENAI_API_KEY=

# Optional one-time Management user bootstrap script values.
MANAGEMENT_EMAIL=
MANAGEMENT_TEMP_PASSWORD=
